# --- Required ---
SUPABASE_URL=https://qxftygfzqouzhznnmrsq.supabase.co
# Paste the service_role JWT (NOT the anon/publishable key). The worker bypasses
# RLS and will refuse to start with anything else.
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-here

# --- Worker identity (must be unique per process) ---
WORKER_ID=contabo-1

# --- Tuning ---
# NOTE: systemd's EnvironmentFile keeps everything after '=' as the value, so
# keep these lines comment-free (no trailing "# ..." on the same line).
HEADLESS=true
# 15 min wait for the similarity score
SUBMISSION_TIMEOUT_MS=900000
# 10 min for file upload + the review screen to appear
UPLOAD_TIMEOUT_MS=600000
# refresh the similarity page every 30 s
POLL_INTERVAL_MS=30000
# how long to sleep when no job/slot is available
CLAIM_IDLE_MS=10000
HEARTBEAT_MS=30000
