# ── Required ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://qxftygfzqouzhznnmrsq.supabase.co

# Paste the service_role JWT — NOT the anon/publishable key.
# The worker bypasses RLS and will refuse to start with anything else.
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-here

# ── Worker identity (must be unique per process) ──────────────────────────────
WORKER_ID=contabo-1

# ── Concurrency ───────────────────────────────────────────────────────────────
# Number of documents to process in parallel (each uses ~0.5 GB RAM + 1 Chrome).
# Up to 3 is safe on a 2 GB VPS. Scale down if you see OOM errors.
CONCURRENCY=3
# Maximum wall-clock time per job including all same-slot retries (ms).
# 3600000 = 1 hour. Job is abandoned and requeued if this elapses.
JOB_TIMEOUT_MS=3600000

# ── Optional: AI self-healing selector fallback ───────────────────────────────
# Comma-separated list of Gemini API keys (5-10 recommended for redundancy).
# Round-robin rotation; on rate-limit (429) the next key is tried automatically.
# The worker behaves identically without keys — AI is a last-resort fallback only.
# Get free keys at https://aistudio.google.com/apikey (no credit card required).
GEMINI_API_KEYS=key1,key2,key3
# Single-key fallback alias (also accepted if GEMINI_API_KEYS is not set).
GEMINI_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────────
# NOTE: systemd EnvironmentFile treats everything after '=' as the raw value,
# so keep value lines free of trailing inline comments.
HEADLESS=true
SUBMISSION_TIMEOUT_MS=900000
UPLOAD_TIMEOUT_MS=600000
POLL_INTERVAL_MS=30000
CLAIM_IDLE_MS=10000
HEARTBEAT_MS=30000
