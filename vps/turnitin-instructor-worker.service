[Unit]
Description=Turnitin Instructor Worker (Similarity + AI pipeline)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=__WORKER_DIR__
EnvironmentFile=__WORKER_DIR__/.env
ExecStart=/usr/bin/node __WORKER_DIR__/dist/index.js
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
