# ── Required ─────────────────────────────────────────────────────────────────
# Identical Supabase project as the student worker — reuse the same values.
SUPABASE_URL=https://qxftygfzqouzhznnmrsq.supabase.co

# Paste the service_role JWT — NOT the anon/publishable key.
# The worker bypasses RLS and will refuse to start with anything else.
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-here

# ── Worker identity ───────────────────────────────────────────────────────────
WORKER_ID=instructor-1

# ── Teaching ──────────────────────────────────────────────────────────────────
# Run the browser headless on the VPS (it has no display). Screenshots are
# uploaded to the Supabase 'training' bucket so you can see every screen.
HEADLESS=true

# Optional: pin the teaching session to one account by label. If unset, the
# first active instructor account is used.
# TEACH_ACCOUNT_LABEL=Instructor #1

# A local sample document to use for "upload" steps while teaching. Any small
# .docx/.pdf works — the real document is substituted automatically during RUN.
TEACH_SAMPLE_FILE=./sample.docx

# ── RUN / replay mode ─────────────────────────────────────────────────────────
# Parallel lane workers sharing one logged-in browser session (each job = 1 tab).
CONCURRENCY=3
# Max wall-clock per job (ms). 3600000 = 1 hour.
JOB_TIMEOUT_MS=3600000
CLAIM_IDLE_MS=10000
HEARTBEAT_MS=30000
# Pin RUN to one instructor account by label (default: first active account).
# RUN_ACCOUNT_LABEL=Instructor #1
