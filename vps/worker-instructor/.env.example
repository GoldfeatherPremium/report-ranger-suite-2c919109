# ── Required ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://qxftygfzqouzhznnmrsq.supabase.co

# Paste the service_role JWT — NOT the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-here

# ── Worker identity (must be unique per process) ──────────────────────────────
# Must start with "instructor-" so the Admin Overview filters it correctly.
WORKER_ID=instructor-1

# ── Concurrency ───────────────────────────────────────────────────────────────
CONCURRENCY=5
JOB_TIMEOUT_MS=3600000
# How long to wait for AI Writing score after similarity arrives (ms). Default 20 min.
# If the AI score doesn't appear in this window the job still completes with
# the Similarity PDF only and ai_report_status='failed'.
AI_WRITING_TIMEOUT_MS=1200000

# ── Optional: AI self-healing selector fallback ───────────────────────────────
GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────────
HEADLESS=true
SUBMISSION_TIMEOUT_MS=900000
UPLOAD_TIMEOUT_MS=600000
POLL_INTERVAL_MS=30000
CLAIM_IDLE_MS=10000
HEARTBEAT_MS=30000
